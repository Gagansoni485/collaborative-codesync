# MongoDB Configuration
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret_key

# Server Configuration
PORT=1600

# AI Provider Configuration (choose one)
# Option 1: Google Gemini (recommended for free tier)
GEMINI_API_KEY=your_gemini_api_key

# Option 2: NVIDIA AI (alternative)
# AI_PROVIDER=nvidia
# NVIDIA_API_KEY=your_nvidia_api_key
# NVIDIA_MODEL_ID=meta/llama-3.1-8b-instruct

# Code Execution API (Optional - for Python, Java, C++)
# Get free API credentials at: https://www.jdoodle.com/compiler-api
# Note: JavaScript runs locally without these credentials
JDOODLE_CLIENT_ID=your_jdoodle_client_id
JDOODLE_CLIENT_SECRET=your_jdoodle_client_secret

# Room Configuration
MAX_ROOM_MEMBERS=4
